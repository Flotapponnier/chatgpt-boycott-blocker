{
  "manifest_version": 3,
  "name": "ChatGPT Block",
  "version": "1.0",
  "description": "Automatically redirects ChatGPT to Claude",
  "permissions": [
    "webNavigation"
  ],
  "host_permissions": [
    "*://*.chatgpt.com/*",
    "*://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
